# gromnie-web testing credentials
# Copy this file to .env and fill in your values.

# --- Proxy auth (gromnie-proxy basic auth) ---
AUTH_ENABLE=true
AUTH_USER=your-proxy-username
AUTH_PASSWORD=your-proxy-password
# AUTH_SECRET is optional; if omitted, a deterministic key is derived from user+pass

# --- AC game server credentials (for the demo login form) ---
GROMNIE_GAME_HOST=play.coldeve.ac
GROMNIE_GAME_PORT=9000
GROMNIE_GAME_ACCOUNT=your-game-account
GROMNIE_GAME_PASSWORD=your-game-password
